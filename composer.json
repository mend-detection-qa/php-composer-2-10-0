{
  "name": "mend-qa/composer-210-install-policy",
  "description": "QA probe: Composer 2.10.0 install-policy BC break (preferred-install, audit exit codes, platform enforcement).",
  "type": "project",
  "license": "proprietary",
  "require": {
    "php": ">=8.2 <8.4",
    "guzzlehttp/guzzle": "^7.8",
    "symfony/console": "^7.1",
    "psr/log": "^3.0",
    "symfony/http-client": "^7.1"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.2",
    "symfony/var-dumper": "^7.1"
  },
  "config": {
    "preferred-install": "dist",
    "sort-packages": true,
    "allow-plugins": {},
    "audit": {
      "abandoned": "report"
    },
    "platform": {
      "php": "8.2.0"
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
