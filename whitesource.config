# Mend Unified Agent configuration for composer-210-install-policy probe.
# Exercises the install_command and tree_command paths simultaneously:
#   - tree_command: reads composer.lock directly (runPreStep=false).
#   - install_command: set runPreStep=true to exercise Composer 2.10
#     install with explicit preferred-install=dist in composer.json.
#
# To exercise tree_command only (lockfile-driven, default):
php.resolveDependencies=true
php.runPreStep=false
php.includeDevDependencies=true
php.removeDuplicateDependencies=false
php.ignoreSourceFiles=true
